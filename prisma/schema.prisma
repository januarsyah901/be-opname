generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model users {
  id              Int               @id @default(autoincrement())
  name            String            @db.VarChar(100)
  username        String            @unique @db.VarChar(50)
  password_hash   String            @db.VarChar(255)
  role            String            @default("kasir") @db.VarChar(20)
  phone           String?           @db.VarChar(50)
  is_active       Boolean           @default(true)
  created_at      DateTime          @default(now()) @db.Timestamptz(6)
  updated_at      DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at      DateTime?         @db.Timestamptz(6)
  stock_movements stock_movements[]
  stock_opnames   stock_opnames[]
  transactions    transactions[]
  refresh_tokens  refresh_tokens[]
}

model bengkel_profile {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(255)
  address          String?
  phone            String?   @db.VarChar(50)
  logo_url         String?
  wa_gateway_token String?
  wa_target_number String?   @db.VarChar(50)
  wa_bot_enabled   Boolean   @default(true)
  wa_template_stok       String? @db.Text
  wa_template_dikerjakan String? @db.Text
  wa_template_selesai    String? @db.Text
  wa_gateway_status    String?   @default("disconnected") @db.VarChar(50)
  wa_gateway_qr        String?   @db.Text
  wa_bot_name          String?   @db.VarChar(150)
  wa_bot_number        String?   @db.VarChar(50)
  wa_bot_avatar        String?   @db.Text
  open_time        String?   @db.VarChar(10)
  close_time       String?   @db.VarChar(10)
  operational_days String?   @db.VarChar(50)
  tax_percentage   Decimal   @default(0) @db.Decimal(5, 2)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
}

model customers {
  id           Int            @id @default(autoincrement())
  name         String         @db.VarChar(150)
  phone        String?        @db.VarChar(20)
  email        String?        @db.VarChar(150)
  address      String?
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  updated_at   DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at   DateTime?      @db.Timestamptz(6)
  vehicles     vehicles[]
  transactions transactions[]
  work_orders  work_orders[]
  reminders    reminders[]
}

model vehicles {
  id           Int            @id @default(autoincrement())
  customer_id  Int
  plate_number String         @unique @db.VarChar(20)
  type         String         @db.VarChar(10)
  brand        String         @default("Unknown") @db.VarChar(100)
  model        String         @default("Unit") @db.VarChar(100)
  year         Int?           @db.SmallInt
  frame_number String?        @db.VarChar(50)
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  customers    customers      @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  transactions transactions[]
  work_orders  work_orders[]
  reminders    reminders[]
}

model categories {
  id          Int           @id @default(autoincrement())
  name        String        @db.VarChar(100)
  description String?
  spare_parts spare_parts[]
}

model spare_parts {
  id                Int                  @id @default(autoincrement())
  category_id       Int?
  name              String               @db.VarChar(200)
  sku               String               @unique @db.VarChar(50)
  barcode_value     String?              @unique @db.VarChar(100)
  barcode_image_url String?
  cost_price        Decimal              @default(0) @db.Decimal(15, 2)
  sell_price        Decimal              @default(0) @db.Decimal(15, 2)
  current_stock     Int                  @default(0)
  minimum_stock     Int                  @default(5)
  unit              String               @default("pcs") @db.VarChar(20)
  created_at        DateTime             @default(now()) @db.Timestamptz(6)
  updated_at        DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at        DateTime?            @db.Timestamptz(6)
  categories        categories?          @relation(fields: [category_id], references: [id])
  stock_movements   stock_movements[]
  stock_opname_items stock_opname_items[]
  transaction_items transaction_items[]
  wa_notifications  wa_notifications[]
}

model stock_movements {
  id              Int          @id @default(autoincrement())
  spare_part_id   Int
  user_id         Int
  type            String       @db.VarChar(30)
  quantity_change Int
  stock_before    Int
  stock_after     Int
  note            String?
  reference_id    Int?
  reference_type  String?      @db.VarChar(50)
  created_at      DateTime     @default(now()) @db.Timestamptz(6)
  spare_parts     spare_parts  @relation(fields: [spare_part_id], references: [id])
  users           users        @relation(fields: [user_id], references: [id])
}

model stock_opnames {
  id                 Int                  @id @default(autoincrement())
  user_id            Int
  session_name       String?              @db.VarChar(200)
  status             String               @default("open") @db.VarChar(10)
  opened_at          DateTime             @default(now()) @db.Timestamptz(6)
  closed_at          DateTime?            @db.Timestamptz(6)
  users              users                @relation(fields: [user_id], references: [id])
  stock_opname_items stock_opname_items[]
}

model stock_opname_items {
  id             Int           @id @default(autoincrement())
  opname_id      Int
  spare_part_id  Int
  system_stock   Int
  physical_count Int           @default(0)
  difference     Int           @default(0)
  note           String?
  stock_opnames  stock_opnames @relation(fields: [opname_id], references: [id], onDelete: Cascade)
  spare_parts    spare_parts   @relation(fields: [spare_part_id], references: [id])

  @@unique([opname_id, spare_part_id])
}

model transactions {
  id                Int                @id @default(autoincrement())
  invoice_number    String             @unique @db.VarChar(50)
  customer_id       Int?
  vehicle_id        Int?
  user_id           Int
  subtotal_amount   Decimal            @default(0) @db.Decimal(15, 2)
  tax_percentage    Decimal            @default(0) @db.Decimal(5, 2)
  tax_amount        Decimal            @default(0) @db.Decimal(15, 2)
  total_amount      Decimal            @default(0) @db.Decimal(15, 2)
  paid_amount       Decimal            @default(0) @db.Decimal(15, 2)
  payment_status    String             @default("belum_bayar") @db.VarChar(20)
  payment_method    String?            @db.VarChar(50)
  notes             String?
  transaction_date  DateTime           @db.Timestamptz(6)
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  customers         customers?         @relation(fields: [customer_id], references: [id])
  vehicles          vehicles?          @relation(fields: [vehicle_id], references: [id])
  users             users              @relation(fields: [user_id], references: [id])
  transaction_items transaction_items[]
}

model transaction_items {
  id             Int           @id @default(autoincrement())
  transaction_id Int
  item_type      String        @db.VarChar(15)
  spare_part_id  Int?
  item_name      String        @db.VarChar(200)
  quantity       Int           @default(1)
  unit_price     Decimal       @default(0) @db.Decimal(15, 2)
  subtotal       Decimal       @default(0) @db.Decimal(15, 2)
  bundle_id      Int?
  transactions   transactions  @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  spare_parts    spare_parts?  @relation(fields: [spare_part_id], references: [id])
  service_bundles service_bundles? @relation(fields: [bundle_id], references: [id])
}

model service_catalog {
  id              Int      @id @default(autoincrement())
  sku             String?  @unique @db.VarChar(50)
  name            String   @db.VarChar(200)
  description     String?
  kategori        String?  @db.VarChar(100)
  standard_price  Decimal  @default(0) @db.Decimal(15, 2)
  durasi_estimasi String?  @db.VarChar(50)
  berlaku_untuk   String   @default("keduanya") @db.VarChar(15)
  garansi         String?  @db.VarChar(100)
  is_active       Boolean  @default(true)
}

model work_orders {
  id               Int       @id @default(autoincrement())
  vehicle_id       Int?
  customer_id      Int?
  layanan          String    @db.VarChar(300)
  keluhan          String?
  status           String    @default("menunggu") @db.VarChar(25)
  mekanik          String?   @db.VarChar(100)
  estimasi_biaya   Decimal   @default(0) @db.Decimal(15, 2)
  estimasi_selesai String?   @db.VarChar(50)
  menginap         Boolean   @default(false)
  complaint_log    String?   @db.Text
  service_bundle_id Int?
  image_url_1      String?   @db.Text
  image_url_2      String?   @db.Text
  image_url_3      String?   @db.Text
  waktu_masuk      DateTime  @default(now()) @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  deleted_at       DateTime? @db.Timestamptz(6)
  vehicles         vehicles? @relation(fields: [vehicle_id], references: [id])
  customers        customers? @relation(fields: [customer_id], references: [id])
  service_bundles  service_bundles? @relation(fields: [service_bundle_id], references: [id])
  checklists       work_order_checklists[]
  inspection       work_order_inspections?
}

model service_bundles {
  id                Int                    @id @default(autoincrement())
  name              String                 @db.VarChar(200)
  description       String?                @db.Text
  price             Decimal                @default(0) @db.Decimal(15, 2)
  is_active         Boolean                @default(true)
  created_at        DateTime               @default(now()) @db.Timestamptz(6)
  updated_at        DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  items             service_bundle_items[]
  work_orders       work_orders[]
  transaction_items transaction_items[]
}

model service_bundle_items {
  id        Int             @id @default(autoincrement())
  bundle_id Int
  task_name String          @db.VarChar(255)
  bundles   service_bundles @relation(fields: [bundle_id], references: [id], onDelete: Cascade)
}

model work_order_checklists {
  id            Int          @id @default(autoincrement())
  work_order_id Int
  task_name     String       @db.VarChar(255)
  is_done       Boolean      @default(false)
  updated_at    DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  work_orders   work_orders  @relation(fields: [work_order_id], references: [id], onDelete: Cascade)
}

model work_order_inspections {
  id                   Int                           @id @default(autoincrement())
  work_order_id        Int                           @unique
  inspection_date      DateTime                      @default(now()) @db.Timestamptz(6)
  kilometer            String?                       @db.VarChar(50)
  pengerjaan           String?                       @db.VarChar(255)
  service_request_note String?                       @db.Text
  repair_note          String?                       @db.Text
  inspected_by         String?                       @db.VarChar(100)
  created_at           DateTime                      @default(now()) @db.Timestamptz(6)
  updated_at           DateTime                      @default(now()) @updatedAt @db.Timestamptz(6)
  work_orders          work_orders                   @relation(fields: [work_order_id], references: [id], onDelete: Cascade)
  items                work_order_inspection_items[]
}

model work_order_inspection_items {
  id            Int                    @id @default(autoincrement())
  inspection_id Int
  section       String                 @db.VarChar(100)
  item_name     String                 @db.VarChar(255)
  status        String                 @default("unchecked") @db.VarChar(20)
  note          String?                @db.Text
  sort_order    Int                    @default(0)
  inspections   work_order_inspections @relation(fields: [inspection_id], references: [id], onDelete: Cascade)
}

model wa_notifications {
  id            Int          @id @default(autoincrement())
  spare_part_id Int?
  wa_number     String       @db.VarChar(20)
  message_body  String
  status        String       @default("pending") @db.VarChar(10)
  sent_at       DateTime?    @db.Timestamptz(6)
  created_at    DateTime     @default(now()) @db.Timestamptz(6)
  spare_parts   spare_parts? @relation(fields: [spare_part_id], references: [id])
}

model refresh_tokens {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique @db.VarChar(255)
  expires_at DateTime @db.Timestamptz(6)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model vehicle_masters {
  id         Int      @id @default(autoincrement())
  brand      String   @db.VarChar(100)
  model      String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@unique([brand, model])
}

model reminders {
  id               Int       @id @default(autoincrement())
  customer_id      Int
  vehicle_id       Int
  jenis_reminder   String    @db.VarChar(100)
  jadwal_tanggal   DateTime  @db.Timestamptz(6)
  odometer_saat    Int?
  odometer_target  Int?
  catatan          String?
  status           String    @default("aktif") @db.VarChar(25)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  deleted_at       DateTime? @db.Timestamptz(6)

  customers        customers @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  vehicles         vehicles  @relation(fields: [vehicle_id], references: [id], onDelete: Cascade)
}
model purchase_orders {
  id            Int                    @id @default(autoincrement())
  no_po         String                 @unique @db.VarChar(50)
  tanggal       DateTime               @db.Timestamptz(6)
  supplier      String                 @db.VarChar(200)
  status        String                 @default("Draft") @db.VarChar(20)
  total_nilai   Decimal                @default(0) @db.Decimal(15, 2)
  estimasi_tiba DateTime?              @db.Timestamptz(6)
  catatan       String?                @db.Text
  created_at    DateTime               @default(now()) @db.Timestamptz(6)
  updated_at    DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  items         purchase_order_items[]
}

model purchase_order_items {
  id             Int             @id @default(autoincrement())
  purchase_id    Int
  spare_part_id  Int?
  sku            String?         @db.VarChar(50)
  nama           String          @db.VarChar(200)
  qty            Int
  harga_satuan   Decimal         @db.Decimal(15, 2)
  purchase_order purchase_orders @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
}
